# --- LLM Proxy (백엔드가 사용) ---
OPENAI_BASE_URL=http://your-proxy-host/v1
OPENAI_API_KEY=your-proxy-api-key
MODEL_NAME=your-model-name

# --- 프로세스 포트/호스트 (선택 — 미설정 시 코드 기본값 사용) ---
AGENT_HOST=127.0.0.1
AGENT_PORT=8000
STREAMLIT_PORT=8501

# --- Notion MCP 인증 (서버 버전에 맞는 변수 하나만 설정) ---
NOTION_TOKEN=ntn_your-notion-integration-token
# 구버전 서버는 아래 헤더 형식을 사용:
# OPENAPI_MCP_HEADERS={"Authorization":"Bearer ntn_...","Notion-Version":"2022-06-28"}
